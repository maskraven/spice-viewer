[Desktop Entry]
Type=Application
Version=1.0
Name=Remote Viewer (SPICE)
GenericName=SPICE Remote Viewer
Comment=Open Proxmox / virt-viewer SPICE connection files (.vv)
Exec=remote-viewer %f
TryExec=remote-viewer
Icon=remote-viewer
Terminal=false
Categories=Network;RemoteAccess;System;
MimeType=application/x-virt-viewer;
Keywords=SPICE;Proxmox;VDI;remote;virt-viewer;console;
StartupNotify=true
